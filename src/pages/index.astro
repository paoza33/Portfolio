---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SideToggle from '../components/SideToggle.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import WritingFeed from '../components/WritingFeed.astro';
import Certs from '../components/Certs.astro';
import { SPL_REPO } from '../consts';
---

<Base>
  <Hero />

  <div class="wrap"><SideToggle /></div>

  <ProjectGrid />

  <!-- Bande SPL : la vitrine des requêtes -->
  <section class="section" id="spl-band">
    <div class="wrap">
      <a class="spl-band reveal" href="/spl/">
        <div class="spl-text">
          <p class="kicker">// detection · splunk</p>
          <h2>80+ requêtes SPL documentées</h2>
          <p class="muted">
            Une bibliothèque de recherches Splunk pour la détection et l'investigation.
            Decouvre une sélection commentée, avec le contexte de menace et le mapping MITRE ATT&CK.
          </p>
        </div>
        <span class="spl-cta mono">Voir la sélection →</span>
      </a>
    </div>
  </section>

  <!-- Bande write-ups : la page dediée -->
  <section class="section" id="wu-band-section">
    <div class="wrap">
      <a class="spl-band wu-band reveal" href="/writeups/">
        <div class="spl-text">
          <p class="kicker">
            <span class="dot dot-blue" aria-hidden="true"></span>
            <span class="dot dot-red" aria-hidden="true"></span>
            // write-ups
          </p>
          <h2>Write-ups de machines, challenges et Sherlocks</h2>
          <p class="muted">
            Ma démarche en conditions réelles, du côté offensif comme défensif.
            Filtrable par angle Blue, Red ou barre de recherche.
          </p>
        </div>
        <span class="spl-cta wu-cta mono">Voir les write-ups →</span>
      </a>
    </div>
  </section>

  <WritingFeed />

  <Certs />
</Base>

<style>
  .section { padding: 30px 0; }
  .spl-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background:
      radial-gradient(ellipse 60% 120% at 88% 50%, var(--green-glow), transparent 70%),
      var(--panel);
    padding: 30px 32px;
    transition: border-color 0.2s, box-shadow 0.25s, transform 0.2s;
  }
  .spl-band:hover {
    border-color: var(--green);
    box-shadow: 0 0 30px -12px var(--green-glow);
    transform: translateY(-2px);
  }
  .spl-text { max-width: 62ch; }
  .spl-text h2 { font-size: clamp(1.4rem, 3vw, 1.9rem); margin: 8px 0 10px; }
  .spl-text p { font-size: 0.95rem; }
  .spl-cta { color: var(--green); font-size: 14px; white-space: nowrap; }

  /* bande write-ups : teinte duale (bleu + rouge), neutre au repos */
  .wu-band {
    background:
      radial-gradient(ellipse 50% 120% at 8% 50%, var(--blue-glow), transparent 60%),
      radial-gradient(ellipse 50% 120% at 92% 50%, var(--red-glow), transparent 60%),
      var(--panel);
  }
  .wu-band:hover {
    border-color: var(--border-strong);
    box-shadow: 0 0 30px -14px var(--blue-glow), 0 0 30px -14px var(--red-glow);
  }
  .wu-cta { color: var(--text); }
  .dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 2px; vertical-align: middle; }
  .dot-blue { background: var(--blue); box-shadow: 0 0 7px var(--blue); }
  .dot-red { background: var(--red); box-shadow: 0 0 7px var(--red); }
</style>
