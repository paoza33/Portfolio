---
import Base from '../layouts/Base.astro';
import { REQUETES } from '../data/spl';
import { SPL_REPO } from '../consts';

const categories = [...new Set(REQUETES.map((r) => r.categorie))];
---

<Base title="Requêtes SPL" description="Sélection commentée de requêtes Splunk pour la détection et l'investigation.">
  <main class="wrap detail">
    <a class="back mono" href="/">← retour</a>

    <header class="detail-head reveal">
      <p class="kicker">// detection · splunk</p>
      <h1>Requetes SPL</h1>
      <p class="detail-sub muted">
        Une sélection commentée parmi plus de 80 requêtes Splunk que je documente pour la detection
        et l'investigation. L'intégralite du dépôt est disponible sur GitHub.
      </p>
      <a class="pill pill-accent repo-link" href={SPL_REPO} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
        Voir les 80+ requêtes sur GitHub
      </a>
    </header>

    <div class="spl-controls reveal">
      <div class="search-box">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 2a8 8 0 1 0 4.9 14.3l5.4 5.4 1.4-1.4-5.4-5.4A8 8 0 0 0 10 2Zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12Z"/></svg>
        <input type="search" id="spl-search" placeholder="Rechercher (nom, technique, MITRE...)" aria-label="Rechercher une requête" />
      </div>
      <div class="cat-bar" role="group" aria-label="Filtrer par categorie">
        <button class="cat-btn is-active" data-cat="">Toutes</button>
        {categories.map((c) => <button class="cat-btn" data-cat={c.toLowerCase()}>{c}</button>)}
      </div>
    </div>

    <p class="spl-count mono faint" id="spl-count">{REQUETES.length} requêtes</p>

    <div class="spl-list" id="spl-list">
      {REQUETES.map((r) => (
        <article
          class="spl-card"
          data-cat={r.categorie.toLowerCase()}
          data-text={`${r.nom} ${r.categorie} ${(r.mitre ?? []).join(' ')} ${r.description}`.toLowerCase()}
        >
          <div class="spl-card-head">
            <h3>{r.nom}</h3>
            <span class="spl-cat mono">{r.categorie}</span>
          </div>
          {r.mitre && r.mitre.length > 0 && (
            <div class="spl-mitre">
              {r.mitre.map((m) => <span class="tag mitre-tag">{m}</span>)}
            </div>
          )}
          <p class="spl-desc muted">{r.description}</p>
          <pre><code>{r.requete}</code></pre>
        </article>
      ))}
    </div>

    <p class="mono muted spl-empty" id="spl-empty" hidden>Aucune requête ne correspond.</p>
  </main>
</Base>

<style>
  .detail { padding: 60px 0 40px; max-width: 880px; }
  .back { display: inline-block; color: var(--accent); font-size: 13px; margin-bottom: 30px; transition: color 0.2s; }
  .back:hover { color: var(--lime); }

  .detail-head h1 { font-size: clamp(2rem, 5vw, 2.8rem); margin: 10px 0; }
  .detail-sub { max-width: 65ch; font-size: 1rem; }
  .repo-link { margin-top: 20px; }
  .pill-accent { border-color: var(--green); color: var(--green); }
  .pill-accent:hover { border-color: var(--lime); color: var(--lime); }

  .spl-controls { display: flex; flex-direction: column; gap: 14px; margin: 36px 0 16px; }
  .search-box {
    display: flex; align-items: center; gap: 10px;
    background: var(--panel); border: 1px solid var(--border-strong);
    border-radius: var(--radius); padding: 0 16px;
  }
  .search-box svg { width: 18px; height: 18px; fill: var(--text-faint); flex: none; }
  .search-box input {
    flex: 1; background: transparent; border: none; outline: none;
    color: var(--text); font-family: var(--font-sans); font-size: 0.98rem; padding: 14px 0;
  }
  .search-box input::placeholder { color: var(--text-faint); }
  .search-box:focus-within { border-color: var(--green); box-shadow: 0 0 18px -6px var(--green-glow); }

  .cat-bar { display: flex; flex-wrap: wrap; gap: 8px; }
  .cat-btn {
    font-family: var(--font-mono); font-size: 12.5px; color: var(--text-dim);
    background: transparent; border: 1px solid var(--border-strong);
    border-radius: 100px; padding: 5px 14px; cursor: pointer; transition: all 0.18s ease;
  }
  .cat-btn:hover { color: var(--text); border-color: var(--text-dim); }
  .cat-btn.is-active { color: var(--green); border-color: var(--green); }

  .spl-count { font-size: 12px; margin-bottom: 16px; }
  .spl-list { display: flex; flex-direction: column; gap: 16px; }

  .spl-card {
    border: 1px solid var(--border);
    border-left: 2px solid var(--green);
    border-radius: var(--radius);
    background: var(--panel);
    padding: 22px 24px;
  }
  .spl-card.hidden { display: none; }
  .spl-card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .spl-card-head h3 { font-size: 1.12rem; }
  .spl-cat { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--green); }
  .spl-mitre { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .mitre-tag { color: var(--lime); border-color: var(--border-strong); }
  .spl-desc { font-size: 0.94rem; margin-top: 12px; }
  .spl-card pre { margin-bottom: 0; }
  .spl-empty { padding: 30px 0; text-align: center; }
</style>

<script>
  const list = document.getElementById('spl-list');
  const search = document.getElementById('spl-search') as HTMLInputElement | null;
  const count = document.getElementById('spl-count');
  const empty = document.getElementById('spl-empty');
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');

  let activeCat = '';
  let query = '';

  function recompute() {
    if (!list) return;
    const cards = list.querySelectorAll<HTMLElement>('.spl-card');
    let visible = 0;
    cards.forEach((el) => {
      const cat = el.dataset.cat || '';
      const text = el.dataset.text || '';
      const okCat = !activeCat || cat === activeCat;
      const okQuery = !query || text.includes(query);
      const show = okCat && okQuery;
      el.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (count) count.textContent = `${visible} ${visible > 1 ? 'requetes' : 'requete'}`;
    if (empty) empty.hidden = visible !== 0;
  }

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat || '';
      catBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
      recompute();
    });
  });
  search?.addEventListener('input', () => {
    query = search.value.trim().toLowerCase();
    recompute();
  });
  recompute();
</script>
