---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ContentDetail from '../../components/ContentDetail.astro';

export async function getStaticPaths() {
  const projets = await getCollection('projets', ({ data }) => !data.draft && !data.externalUrl);
  return projets.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;
---

<Base title={data.title} description={data.summary}>
  <ContentDetail
    title={data.title}
    side={data.side}
    tags={data.tags}
    date={data.date}
    updated={data.updated}
    backHref="/#projets"
    backLabel="tous les projets"
    kicker="// projet"
  >
    <Content />
  </ContentDetail>
</Base>
