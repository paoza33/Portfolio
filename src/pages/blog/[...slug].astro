---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ContentDetail from '../../components/ContentDetail.astro';

export async function getStaticPaths() {
  const articles = await getCollection('blog', ({ data }) => !data.draft);
  return articles.map((a) => ({
    params: { slug: a.slug },
    props: { entry: a },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;
---

<Base title={data.title} description={data.summary}>
  <ContentDetail
    title={data.title}
    side={data.side}
    tags={data.tags}
    date={data.date}
    updated={data.updated}
    backHref="/#blog"
    backLabel="toutes les notes"
    kicker="// note"
  >
    <Content />
  </ContentDetail>
</Base>
