---
import { IDENTITE, LIENS, SPL_REPO } from '../consts';
const annee = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-col">
      <p class="mono footer-name">{IDENTITE.prenom} {IDENTITE.nom} <span class="faint">/ {IDENTITE.pseudo}</span></p>
      <p class="muted footer-tag">{IDENTITE.titre}</p>
    </div>

    <nav class="footer-links mono" aria-label="Liens du pied de page">
      <a href={SPL_REPO} target="_blank" rel="noopener">Requetes SPL ↗</a>
      {LIENS.github && <a href={LIENS.github} target="_blank" rel="noopener">GitHub ↗</a>}
      {LIENS.linkedin && <a href={LIENS.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>}
      {LIENS.hackthebox && <a href={LIENS.hackthebox} target="_blank" rel="noopener">Hack The Box ↗</a>}
      {LIENS.email && <a href={`mailto:${LIENS.email}`}>Me contacter</a>}
    </nav>
  </div>
  <div class="wrap footer-bottom">
    <span class="faint mono">© {annee} · construit avec Astro</span>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border); margin-top: 40px; padding: 36px 0 28px; }
  .footer-inner { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .footer-name { font-size: 0.95rem; color: var(--text); }
  .footer-tag { font-size: 0.85rem; margin-top: 4px; }

  .footer-links { display: flex; flex-wrap: wrap; gap: 18px; align-items: center; }
  .footer-links a { font-size: 13px; color: var(--text-dim); transition: color 0.2s; }
  .footer-links a:hover { color: var(--lime); }

  .footer-bottom { margin-top: 26px; }
  .footer-bottom span { font-size: 12px; }
</style>
