---
import { IDENTITE, LIENS } from '../consts';

const nomComplet = `${IDENTITE.prenom} ${IDENTITE.nom}`;
---

<header class="hero">
  <div class="wrap hero-inner">
    <p class="kicker reveal" style="animation-delay: 0.05s">// portfolio cybersecurite</p>

    <h1 class="reveal" style="animation-delay: 0.12s">
      {nomComplet}
      <span class="pseudo">({IDENTITE.pseudo})</span>
    </h1>

    <p class="role reveal" style="animation-delay: 0.2s">
      {IDENTITE.titre}
      <span class="role-dim">{IDENTITE.sousTitre}</span>
    </p>

    <p class="pitch reveal" style="animation-delay: 0.28s">{IDENTITE.pitch}</p>

    <nav class="links reveal" style="animation-delay: 0.36s" aria-label="Liens externes">
      {LIENS.hackthebox && (
        <a class="pill" href={LIENS.hackthebox} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 3 7v10l9 5 9-5V7l-9-5Zm0 2.3 6.5 3.6L12 11.5 5.5 7.9 12 4.3Zm-7 5.3 6 3.4v6.8l-6-3.3V9.6Zm14 0v6.9l-6 3.3v-6.8l6-3.4Z"/></svg>
          Hack The Box
        </a>
      )}
      {LIENS.github && (
        <a class="pill" href={LIENS.github} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
          GitHub
        </a>
      )}
      {LIENS.linkedin && (
        <a class="pill" href={LIENS.linkedin} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2ZM8 19H5V9h3v10ZM6.5 7.7a1.8 1.8 0 1 1 0-3.5 1.8 1.8 0 0 1 0 3.5ZM19 19h-3v-5c0-1.2 0-2.7-1.6-2.7S12.5 12.5 12.5 14v5h-3V9h2.9v1.4h.04c.4-.8 1.4-1.6 2.9-1.6 3.1 0 3.7 2 3.7 4.7V19Z"/></svg>
          LinkedIn
        </a>
      )}
      {LIENS.email && (
        <a class="pill pill-accent" href={`mailto:${LIENS.email}`}>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm9 7.2 8-5.2H4l8 5.2ZM4 8.5V18h16V8.5l-8 5.2-8-5.2Z"/></svg>
          Me contacter
        </a>
      )}
      {LIENS.cv && (
        <a class="pill" href={LIENS.cv} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v10.6l3.3-3.3 1.4 1.4L12 16.4 7.3 11.7l1.4-1.4L12 13.6V3h0Zm-7 14h14v2H5v-2Z"/></svg>
          CV (PDF)
        </a>
      )}
    </nav>
  </div>
</header>

<style>
  .hero { padding: 88px 0 56px; position: relative; }
  .hero-inner { max-width: 820px; }

  h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    margin: 14px 0 0;
  }
  .pseudo {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.42em;
    color: var(--accent);
    vertical-align: middle;
    transition: color 0.5s ease;
  }

  .role {
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 2.2vw, 1.15rem);
    color: var(--text);
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
  }
  .role-dim {
    color: var(--accent);
    font-size: 0.82em;
    transition: color 0.5s ease;
  }
  .role-dim::before { content: '· '; color: var(--text-faint); }

  .pitch {
    margin-top: 26px;
    font-size: 1.05rem;
    color: var(--text-dim);
    max-width: 65ch;
  }

  .links {
    margin-top: 34px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .pill-accent {
    border-color: var(--accent);
    color: var(--accent);
  }
  .pill-accent:hover {
    color: var(--lime);
    border-color: var(--lime);
  }
</style>
