---
import { CERTIFS } from '../consts';

const statutLabel: Record<string, string> = {
  'obtenu': 'obtenu',
  'en-cours': 'en cours',
  'planifie': 'a venir',
};
---

<section class="section certs" id="certifs">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="kicker">// certifications</p>
      <h2>Parcours de certification</h2>
    </div>

    <div class="cert-grid">
      {CERTIFS.map((c) => (
        <div class={`cert cert-${c.statut}`}>
          <div class="cert-top">
            <span class="cert-sigle mono">{c.sigle}</span>
            <span class={`cert-badge cert-badge-${c.statut} mono`}>{statutLabel[c.statut]}</span>
          </div>
          <p class="cert-nom muted">{c.nom}</p>
          {c.note && <p class="cert-note faint mono">{c.note}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .certs { padding: 30px 0; }
  .section-head { margin-bottom: 22px; }
  .section-head h2 { font-size: clamp(1.6rem, 3.5vw, 2.1rem); margin-top: 8px; }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }
  .cert {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
    background: var(--panel);
  }
  /* obtenu : plein vert ; en cours : contour vert ; planifie : estompe */
  .cert-obtenu { border-color: var(--green); box-shadow: 0 0 22px -10px var(--green-glow); }
  .cert-en-cours { border-color: var(--border-strong); }
  .cert-planifie { opacity: 0.62; }

  .cert-top { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .cert-sigle { font-size: 1.25rem; font-weight: 600; color: var(--text); letter-spacing: 0.03em; }

  .cert-badge { font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; padding: 3px 10px; border-radius: 100px; }
  .cert-badge-obtenu { background: var(--green); color: #04130a; }
  .cert-badge-en-cours { border: 1px solid var(--green); color: var(--green); }
  .cert-badge-planifie { border: 1px solid var(--text-faint); color: var(--text-faint); }

  .cert-nom { font-size: 0.88rem; margin-top: 12px; line-height: 1.5; }
  .cert-note { font-size: 11.5px; margin-top: 8px; }
</style>
